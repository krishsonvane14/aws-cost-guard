# AWS credentials
# When running locally or in Docker, set these explicitly.
# In GitHub Actions, use repository secrets instead.
# When running on EC2/ECS/Lambda, use an IAM role (omit the key vars entirely).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Webhook destination (Slack, Teams, Discord, etc.)
WEBHOOK_URL=https://hooks.example.com/your-webhook-url

# Alert fires when total cost exceeds this USD amount
COST_THRESHOLD_USD=100

# How many days back to query
LOOKBACK_DAYS=30
